{{ 'pictory-products-grid.css' | asset_url | stylesheet_tag }}

<div class="pictory-products-grid-section"
  data-section-id="{{ section.id }}"
  data-title-size="{{ section.settings.title_size }}"
  data-title-color="{{ section.settings.title_color }}"
  data-background-color="{{ section.settings.background_color }}"
  data-padding-top="{{ section.settings.section_padding_top }}"
  data-padding-bottom="{{ section.settings.section_padding_bottom }}"
  data-product-title-size="{{ section.settings.product_title_size }}"
  data-product-title-color="{{ section.settings.product_title_color }}"
  data-description-size="{{ section.settings.description_size }}"
  data-description-color="{{ section.settings.description_color }}"
  data-button-size="{{ section.settings.button_size }}"
  data-button-padding="{{ section.settings.button_padding }}"
  data-button-border-radius="{{ section.settings.button_border_radius }}"
  data-button-bg-color="{{ section.settings.button_bg_color }}"
  data-button-text-color="{{ section.settings.button_text_color }}"
  data-button-hover-bg-color="{{ section.settings.button_hover_bg_color }}"
  data-mobile-title-size="{{ section.settings.mobile_title_size }}"
  data-mobile-title-color="{{ section.settings.mobile_title_color }}"
  data-mobile-product-title-size="{{ section.settings.mobile_product_title_size }}"
  data-mobile-product-title-color="{{ section.settings.mobile_product_title_color }}"
  data-mobile-description-size="{{ section.settings.mobile_description_size }}"
  data-mobile-description-color="{{ section.settings.mobile_description_color }}"
  data-mobile-button-size="{{ section.settings.mobile_button_size }}"
  data-mobile-button-padding="{{ section.settings.mobile_button_padding }}"
  data-mobile-button-border-radius="{{ section.settings.mobile_button_border_radius }}"
  data-mobile-button-bg-color="{{ section.settings.mobile_button_bg_color }}"
  data-mobile-button-text-color="{{ section.settings.mobile_button_text_color }}"
  data-mobile-button-hover-bg-color="{{ section.settings.mobile_button_hover_bg_color }}"
  style="background-color: {{ section.settings.background_color }}; padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px 0;">
  
  <div class="container">
    {% if section.settings.title != blank %}
      <h2 class="section-title">{{ section.settings.title }}</h2>
    {% endif %}
    
    <div class="products-grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'product_item' %}
            <div class="product-item" {{ block.shopify_attributes }}>
              {% if block.settings.product_image != blank %}
                <div class="product-image">
                  <a href="{{ block.settings.button_link | default: '#' }}" class="product-link">
                    <img src="{{ block.settings.product_image | image_url: width: 600 }}" 
                         alt="{{ block.settings.product_title | escape }}"
                         loading="lazy">
                    <div class="product-overlay">
                      {% if block.settings.product_title != blank %}
                        <h3 class="product-title">{{ block.settings.product_title }}</h3>
                      {% endif %}
                      {% if block.settings.product_description != blank %}
                        <p class="product-description">{{ block.settings.product_description }}</p>
                      {% endif %}
                    </div>
                  </a>
                </div>
              {% endif %}
              
              <!-- Mobile version - separate structure -->
              <div class="mobile-content">
                {% if block.settings.product_image != blank %}
                  <div class="mobile-image">
                    <img src="{{ block.settings.product_image | image_url: width: 400 }}" 
                         alt="{{ block.settings.product_title | escape }}"
                         loading="lazy">
                  </div>
                {% endif %}
                
                <div class="mobile-text-content">
                  {% if block.settings.product_title != blank %}
                    <h3 class="product-title">{{ block.settings.product_title }}</h3>
                  {% endif %}
                  
                  {% if block.settings.product_description != blank %}
                    <p class="product-description">{{ block.settings.product_description }}</p>
                  {% endif %}
                  
                  {% if block.settings.button_text != blank %}
                    <a href="{{ block.settings.button_link | default: '#' }}" 
                       class="product-button">
                      {{ block.settings.button_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</div>

<script src="{{ 'pictory-products-grid.js' | asset_url }}" defer></script>

<script>
// Ensure live preview works in Shopify theme editor
document.addEventListener('DOMContentLoaded', function() {
  // Initialize immediately for theme editor
  if (window.Shopify && window.Shopify.designMode) {
    setTimeout(function() {
      const sections = document.querySelectorAll('.pictory-products-grid-section');
      sections.forEach(section => {
        if (!section.pictoryInitialized) {
          new PictoryProductsGrid(section);
          section.pictoryInitialized = true;
        }
      });
    }, 100);
  }
});

// Handle theme editor events for live preview
if (window.Shopify && window.Shopify.designMode) {
  document.addEventListener('shopify:section:select', function(event) {
    if (event.target.classList.contains('pictory-products-grid-section')) {
      const section = event.target;
      if (!section.pictoryInitialized) {
        new PictoryProductsGrid(section);
        section.pictoryInitialized = true;
      }
    }
  });
}
</script>

