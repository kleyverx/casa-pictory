{{ 'multi-image-carousel.css' | asset_url | stylesheet_tag }}

<div class="multi-image-carousel-section" 
     data-image-size="{{ section.settings.image_size }}"
     data-title-size="{{ section.settings.title_size }}"
  data-description-size="{{ section.settings.description_size }}"
  data-title-color="{{ section.settings.title_color }}"
  data-description-color="{{ section.settings.description_color }}"
  data-slide-title-size="{{ section.settings.slide_title_size }}"
  data-slide-description-size="{{ section.settings.slide_description_size }}"
  data-slide-title-color="{{ section.settings.slide_title_color }}"
  data-slide-description-color="{{ section.settings.slide_description_color }}"
  data-button-size="{{ section.settings.button_size }}"
  data-button-padding="{{ section.settings.button_padding }}"
  data-button-border-radius="{{ section.settings.button_border_radius }}"
  data-button-border-color="{{ section.settings.button_border_color }}"
  data-button-bg-color="{{ section.settings.button_bg_color }}"
  data-button-text-color="{{ section.settings.button_text_color }}"
  data-button-hover-bg-color="{{ section.settings.button_hover_bg_color }}"
  data-mobile-title-size="{{ section.settings.mobile_title_size }}"
  data-mobile-description-size="{{ section.settings.mobile_description_size }}"
  data-mobile-title-color="{{ section.settings.mobile_title_color }}"
  data-mobile-description-color="{{ section.settings.mobile_description_color }}"
  data-mobile-slide-title-size="{{ section.settings.mobile_slide_title_size }}"
  data-mobile-slide-description-size="{{ section.settings.mobile_slide_description_size }}"
  data-mobile-slide-title-color="{{ section.settings.mobile_slide_title_color }}"
  data-mobile-slide-description-color="{{ section.settings.mobile_slide_description_color }}"
  data-mobile-button-size="{{ section.settings.mobile_button_size }}"
  data-mobile-button-padding="{{ section.settings.mobile_button_padding }}"
  data-mobile-button-border-radius="{{ section.settings.mobile_button_border_radius }}"
  data-mobile-button-border-color="{{ section.settings.mobile_button_border_color }}"
  data-mobile-button-bg-color="{{ section.settings.mobile_button_bg_color }}"
  data-mobile-button-text-color="{{ section.settings.mobile_button_text_color }}"
  data-mobile-button-hover-bg-color="{{ section.settings.mobile_button_hover_bg_color }}"
  data-mobile-button-border-radius="{{ section.settings.mobile_button_border_radius }}"
     id="carousel-{{ section.id }}">
  
  <div class="container">
    {% if section.settings.title != blank %}
      <div class="carousel-header">
        <h2 class="carousel-title">{{ section.settings.title }}</h2>
        {% if section.settings.description != blank %}
          <p class="carousel-description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="multi-image-carousel-wrapper"
         data-autoplay="{{ section.settings.autoplay }}"
         data-autoplay-speed="{{ section.settings.autoplay_speed }}"
         data-infinite="{{ section.settings.infinite }}">
      
      <div class="multi-image-carousel">
        <div class="carousel-track-container">
          <div class="carousel-track">
            {% for block in section.blocks %}
              <div class="carousel-slide" {{ block.shopify_attributes }}>
                <div class="slide-content">
                  {% if block.settings.image != blank %}
                    <div class="slide-image-wrapper">
                      <img src="{{ block.settings.image | image_url: width: 500 }}"
                           alt="{{ block.settings.image.alt | default: block.settings.title }}"
                           class="slide-image"
                           loading="lazy"
                           width="500"
                           height="500">
                    </div>
                  {% endif %}
                  
                  <div class="slide-text-content">
                    {% if block.settings.title != blank %}
                      <h3 class="slide-title">{{ block.settings.title }}</h3>
                    {% endif %}
                    
                    {% if block.settings.description != blank %}
                      <p class="slide-description">{{ block.settings.description }}</p>
                    {% endif %}
                    
                    {% if block.settings.button_text != blank and block.settings.button_url != blank %}
                      <a href="{{ block.settings.button_url }}" 
                         class="slide-button"
                         {% if block.settings.button_url contains 'http' %}target="_blank" rel="noopener"{% endif %}>
                        {{ block.settings.button_text }}
                      </a>
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        {% if section.blocks.size > 1 %}
          <button class="carousel-nav carousel-nav-prev" type="button" aria-label="Imagen anterior">
            <svg xmlns="http://www.w3.org/2000/svg" id="Capa_1" data-name="Capa 1" viewBox="0 0 500 500" style="transform: scaleX(-1);">
              <defs>
                <style>
                  .cls-2 {
                    fill: none;
                    stroke: #285074;
                    stroke-linecap: round;
                    stroke-linejoin: round;
                    stroke-width: 20px;
                  }
                </style>
              </defs>
              <polyline class="cls-2" points="200.39 155.74 299.68 240.23 200.32 324.78"/>
            </svg>
          </button>
          
          <button class="carousel-nav carousel-nav-next" type="button" aria-label="Siguiente imagen">
            <svg xmlns="http://www.w3.org/2000/svg" id="Capa_1" data-name="Capa 1" viewBox="0 0 500 500">
              <defs>
                <style>
                  .cls-2 {
                    fill: none;
                    stroke: #285074;
                    stroke-linecap: round;
                    stroke-linejoin: round;
                    stroke-width: 20px;
                  }
                </style>
              </defs>
              <polyline class="cls-2" points="200.39 155.74 299.68 240.23 200.32 324.78"/>
            </svg>
          </button>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script src="{{ 'multi-image-carousel.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Carrusel Imágenes",
  "tag": "section",
  "class": "section-carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Galería de Imágenes"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción de la sección",
      "default": "Explora nuestra colección de imágenes"
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "Tamaño de las imágenes",
      "options": [
        {
          "value": "300",
          "label": "Pequeño (300px)"
        },
        {
          "value": "350",
          "label": "Mediano-Pequeño (350px)"
        },
        {
          "value": "400",
          "label": "Mediano (400px)"
        },
        {
          "value": "450",
          "label": "Mediano-Grande (450px)"
        },
        {
          "value": "500",
          "label": "Grande (500px)"
        }
      ],
      "default": "400"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Reproducción automática",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 1000,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "label": "Velocidad de reproducción automática",
      "default": 3000
    },
    {
      "type": "checkbox",
      "id": "infinite",
      "label": "Bucle infinito",
      "default": true
    },
    {
      "type": "header",
      "content": "Configuración de Texto"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título principal",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de la descripción de la sección",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Color del título principal",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Color de la descripción de la sección",
      "default": "#5a6c7d"
    },
    {
      "type": "range",
      "id": "slide_title_size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título de imagen",
      "default": 20
    },
    {
      "type": "range",
      "id": "slide_description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de la descripción",
      "default": 15
    },
    {
      "type": "color",
      "id": "slide_title_color",
      "label": "Color del título de imagen",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "slide_description_color",
      "label": "Color de la descripción de imagen",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Configuración del Botón"
    },
    {
      "type": "range",
      "id": "button_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamaño del texto del botón",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Padding del botón",
      "default": 12
    },

    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 25,
      "step": 1,
      "unit": "px",
      "label": "Redondeo del botón",
      "default": 5
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Color del borde del botón",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Color de fondo del botón",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Color del texto del botón",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Color de fondo del botón (hover)",
      "default": "#555555"
    },
    {
      "type": "header",
      "content": "Configuración Mobile"
    },
    {
      "type": "range",
      "id": "mobile_button_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Tamaño del texto del botón (Mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "mobile_button_padding",
      "min": 6,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Padding del botón (Mobile)",
      "default": 10
    },
    {
      "type": "range",
      "id": "mobile_button_border_radius",
      "min": 0,
      "max": 25,
      "step": 1,
      "unit": "px",
      "label": "Redondeo del botón (Mobile)",
      "default": 3
    },
    {
      "type": "range",
      "id": "mobile_title_size",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título principal (Mobile)",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_description_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de la descripción de la sección (Mobile)",
      "default": 14
    },
    {
      "type": "color",
      "id": "mobile_title_color",
      "label": "Color del título principal (Mobile)",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "mobile_description_color",
      "label": "Color de la descripción de la sección (Mobile)",
      "default": "#5a6c7d"
    },
    {
      "type": "range",
      "id": "mobile_slide_title_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Tamaño del título de imagen (Mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "mobile_slide_description_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Tamaño de la descripción (Mobile)",
      "default": 12
    },
    {
      "type": "color",
      "id": "mobile_slide_title_color",
      "label": "Color del título de imagen (Mobile)",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "mobile_slide_description_color",
      "label": "Color de la descripción de imagen (Mobile)",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "mobile_button_border_color",
      "label": "Color del borde del botón (Mobile)",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "mobile_button_bg_color",
      "label": "Color de fondo del botón (Mobile)",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "mobile_button_text_color",
      "label": "Color del texto del botón (Mobile)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "mobile_button_hover_bg_color",
      "label": "Color de fondo del botón (hover) (Mobile)",
      "default": "#555555"
    }
  ],
  "blocks": [
    {
      "type": "image_slide",
      "name": "Imagen del carrusel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título de la imagen",
          "default": "Título de la imagen"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción de la imagen",
          "default": "Descripción de la imagen"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Texto del botón"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Enlace del botón"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carrusel Imágenes",
      "blocks": [
        {
          "type": "image_slide",
          "settings": {
            "title": "Primera Imagen",
            "description": "Descripción de la primera imagen"
          }
        },
        {
          "type": "image_slide",
          "settings": {
            "title": "Segunda Imagen",
            "description": "Descripción de la segunda imagen"
          }
        },
        {
          "type": "image_slide",
          "settings": {
            "title": "Tercera Imagen",
            "description": "Descripción de la tercera imagen"
          }
        }
      ]
    }
  ]
}
{% endschema %}